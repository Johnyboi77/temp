// src/lib/email/templates/booking.tsx

import * as React from 'react';
import { Section, Heading, Text, Button } from '@react-email/components';
import {
  EmailLayout,
  heading,
  text,
  buttonContainer,
  button,
  smallText,
  infoBox,
  infoLabel,
  infoValue,
} from './shared';

// =============================================================================
// Buchungsbestätigung
// =============================================================================

interface BookingConfirmationProps {
  bookingId: string;
  serviceName: string;
  providerName: string;
  date: string;
  time: string;
  price: number;
  customerName: string;
  address?: string;
}

export const BookingConfirmation = ({
  bookingId,
  serviceName,
  providerName,
  date,
  time,
  price,
  customerName,
  address,
}: BookingConfirmationProps) => (
  <EmailLayout>
    <Heading style={heading}>Buchung bestätigt ✓</Heading>

    <Text style={text}>
      Hallo {customerName},
    </Text>

    <Text style={text}>
      Ihre Buchung wurde erfolgreich bestätigt!
    </Text>

    <Section style={infoBox}>
      <Text style={infoLabel}>Dienstleistung:</Text>
      <Text style={infoValue}>{serviceName}</Text>

      <Text style={infoLabel}>Anbieter:</Text>
      <Text style={infoValue}>{providerName}</Text>

      <Text style={infoLabel}>Datum:</Text>
      <Text style={infoValue}>{date}</Text>

      <Text style={infoLabel}>Uhrzeit:</Text>
      <Text style={infoValue}>{time}</Text>

      {address && (
        <>
          <Text style={infoLabel}>Adresse:</Text>
          <Text style={infoValue}>{address}</Text>
        </>
      )}

      <Text style={infoLabel}>Preis:</Text>
      <Text style={infoValue}>{price.toFixed(2)} €</Text>

      <Text style={infoLabel}>Buchungsnummer:</Text>
      <Text style={infoValue}>{bookingId}</Text>
    </Section>

    <Section style={buttonContainer}>
      <Button href={`https://frey-one.com/bookings/${bookingId}`} style={button}>
        Buchung ansehen
      </Button>
    </Section>

    <Text style={smallText}>
      Sie erhalten eine Erinnerung 24 Stunden vor Ihrem Termin.
    </Text>
  </EmailLayout>
);

// =============================================================================
// Buchungsstornierung
// =============================================================================

interface BookingCancellationProps {
  bookingId: string;
  serviceName: string;
  providerName: string;
  date: string;
  time: string;
  customerName: string;
  reason?: string;
}

export const BookingCancellation = ({
  bookingId,
  serviceName,
  providerName,
  date,
  time,
  customerName,
  reason,
}: BookingCancellationProps) => (
  <EmailLayout>
    <Heading style={heading}>Buchung storniert</Heading>

    <Text style={text}>
      Hallo {customerName},
    </Text>

    <Text style={text}>
      Ihre Buchung wurde storniert.
    </Text>

    <Section style={infoBox}>
      <Text style={infoLabel}>Dienstleistung:</Text>
      <Text style={infoValue}>{serviceName}</Text>

      <Text style={infoLabel}>Anbieter:</Text>
      <Text style={infoValue}>{providerName}</Text>

      <Text style={infoLabel}>Datum:</Text>
      <Text style={infoValue}>{date}</Text>

      <Text style={infoLabel}>Uhrzeit:</Text>
      <Text style={infoValue}>{time}</Text>

      <Text style={infoLabel}>Buchungsnummer:</Text>
      <Text style={infoValue}>{bookingId}</Text>

      {reason && (
        <>
          <Text style={infoLabel}>Grund:</Text>
          <Text style={infoValue}>{reason}</Text>
        </>
      )}
    </Section>

    <Text style={text}>
      Eventuelle Rückerstattungen werden gemäß unseren Stornierungsbedingungen bearbeitet.
    </Text>

    <Section style={buttonContainer}>
      <Button href="https://frey-one.com/search" style={button}>
        Neue Buchung vornehmen
      </Button>
    </Section>
  </EmailLayout>
);

