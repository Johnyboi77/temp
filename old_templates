// =============================================================================
// Bewertungsanfrage
// =============================================================================

interface ReviewRequestProps {
  customerName: string;
  serviceName: string;
  providerName: string;
  bookingId: string;
}

export const ReviewRequest = ({
  customerName,
  serviceName,
  providerName,
  bookingId,
}: ReviewRequestProps) => (
  <EmailLayout>
    <Heading style={heading}>Bewerten Sie Ihre letzte Buchung</Heading>

    <Text style={text}>
      Hallo {customerName},
    </Text>

    <Text style={text}>
      wie war Ihre Erfahrung mit <span style={{ fontWeight: 'bold' }}>{providerName}</span>?
    </Text>

    <Text style={text}>
      Ihre Bewertung hilft anderen Kunden bei der Entscheidung und unterstützt
      Anbieter dabei, ihren Service zu verbessern.
    </Text>

    <Section style={infoBox}>
      <Text style={infoLabel}>Dienstleistung:</Text>
      <Text style={infoValue}>{serviceName}</Text>

      <Text style={infoLabel}>Anbieter:</Text>
      <Text style={infoValue}>{providerName}</Text>
    </Section>

    <Section style={buttonContainer}>
      <Button href={`https://frey-one.com/bookings/${bookingId}/review`} style={button}>
        Jetzt bewerten
      </Button>
    </Section>

    <Text style={smallText}>
      Die Bewertung dauert nur 1 Minute! ⭐
    </Text>
  </EmailLayout>
);

